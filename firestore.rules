rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. catch-all global security lock
    match /{document=**} {
      allow read, write: if false;
    }

    // Core Secure Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ================== Collection Match Blocks ==================

    // UserProfile Entity Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); // Allow searching registered players
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) && incoming().updatedAt == request.time && (
        incoming().diff(existing()).affectedKeys().hasOnly(['uid', 'email', 'status', 'updatedAt', 'displayName', 'photoURL', 'maxUnlockedLevel', 'completedLevels', 'maxUnlockedLifestyleLevel', 'completedLifestyleLevels', 'gymPoints', 'sprintLevel', 'cyclingLevel', 'swimmingLevel', 'strengthLevel'])
      );
    }

    function isValidUserProfile(data) {
      return (!('uid' in data) || data.uid == request.auth.uid)
        && (!('email' in data) || (data.email is string && data.email.size() <= 150))
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 80))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (!('status' in data) || data.status in ['online', 'offline', 'ingame'])
        && (!('maxUnlockedLevel' in data) || (data.maxUnlockedLevel is int || data.maxUnlockedLevel is float || data.maxUnlockedLevel is number))
        && (!('completedLevels' in data) || data.completedLevels is list)
        && (!('maxUnlockedLifestyleLevel' in data) || (data.maxUnlockedLifestyleLevel is int || data.maxUnlockedLifestyleLevel is float || data.maxUnlockedLifestyleLevel is number))
        && (!('completedLifestyleLevels' in data) || data.completedLifestyleLevels is list)
        && (!('gymPoints' in data) || (data.gymPoints is int || data.gymPoints is float || data.gymPoints is number))
        && (!('sprintLevel' in data) || (data.sprintLevel is int || data.sprintLevel is float || data.sprintLevel is number))
        && (!('cyclingLevel' in data) || (data.cyclingLevel is int || data.cyclingLevel is float || data.cyclingLevel is number))
        && (!('swimmingLevel' in data) || (data.swimmingLevel is int || data.swimmingLevel is float || data.swimmingLevel is number))
        && (!('strengthLevel' in data) || (data.strengthLevel is int || data.strengthLevel is float || data.strengthLevel is number));
    }

    // Friendships Entity Collection Rules
    match /friendships/{friendshipId} {
      allow get: if isSignedIn() && isValidId(friendshipId) && (existing().user1 == request.auth.uid || existing().user2 == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
      allow create: if isSignedIn() && isValidId(friendshipId) && (incoming().user1 == request.auth.uid || incoming().user2 == request.auth.uid) && isValidFriend(incoming()) && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(friendshipId) && (existing().user1 == request.auth.uid || existing().user2 == request.auth.uid) && isValidFriend(incoming()) && incoming().updatedAt == request.time && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isSignedIn() && isValidId(friendshipId) && (existing().user1 == request.auth.uid || existing().user2 == request.auth.uid);
    }

    function isValidFriend(data) {
      return (data.user1 == request.auth.uid || data.user2 == request.auth.uid)
        && (!('user1Name' in data) || (data.user1Name is string && data.user1Name.size() <= 80))
        && (!('user2Name' in data) || (data.user2Name is string && data.user2Name.size() <= 80))
        && (!('user1Email' in data) || (data.user1Email is string && data.user1Email.size() <= 150))
        && (!('user2Email' in data) || (data.user2Email is string && data.user2Email.size() <= 150))
        && (!('user1Photo' in data) || (data.user1Photo is string && data.user1Photo.size() <= 1000))
        && (!('user2Photo' in data) || (data.user2Photo is string && data.user2Photo.size() <= 1000))
        && (!('status' in data) || data.status in ['pending', 'accepted']);
    }

    // Live Invitations Collection Rules
    match /invitations/{invitationId} {
      allow get: if isSignedIn() && isValidId(invitationId) && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(invitationId) && incoming().senderId == request.auth.uid && isValidInvitation(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(invitationId) && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status in ['pending', 'accepted', 'declined'];
      allow delete: if isSignedIn() && isValidId(invitationId) && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
    }

    function isValidInvitation(data) {
      return (data.senderId == request.auth.uid || data.receiverId == request.auth.uid)
        && (!('senderName' in data) || (data.senderName is string && data.senderName.size() <= 80))
        && (!('roomCode' in data) || (data.roomCode is string && data.roomCode.size() <= 20))
        && (!('status' in data) || data.status in ['pending', 'accepted', 'declined']);
    }
  }
}
